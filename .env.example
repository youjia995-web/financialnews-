# ============================================
# 本地开发环境配置
# ============================================

# AI API Keys
DEEPSEEK_API_KEY="sk-xxx"
QWEN_API_KEY="sk-xxx"
TAVILY_API_KEY="tvly-dev-xxx"

# Stock Data
TUSHARE_TOKEN="your_tushare_token"
TUSHARE_API_URL="http://api.tushare.pro"

# NextAuth.js
NEXTAUTH_SECRET="your_random_secret_key_here"
NEXTAUTH_URL="http://localhost:6081"

# ============================================
# 数据库配置（二选一）
# ============================================

# 本地开发 - SQLite（默认）
# DATABASE_URL="file:./prisma/dev.db"

# 生产环境 - PostgreSQL（Vercel 部署时使用）
# 推荐使用 Neon、Supabase 或其他 PostgreSQL 服务
# DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ============================================
# Vercel 部署说明
# ============================================
# 1. 在 Vercel 项目设置中添加环境变量 DATABASE_URL
# 2. 使用 Neon/Supabase 等 PostgreSQL 连接字符串
# 3. 部署后运行: npx prisma db push --schema=prisma/schema.postgres.prisma
# 4. 创建管理员: node scripts/set-admin.js admin your_password
