{
  "name": "finance-news-aggregator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 6081",
    "build": "prisma generate --schema=prisma/schema.postgres.prisma && next build",
    "start": "next start",
    "postinstall": "prisma generate --schema=prisma/schema.postgres.prisma",
    "fetcher": "node scripts/fetcher.js",
    "notes": "node scripts/run-notes.js",
    "db:push": "prisma db push --schema=prisma/schema.sqlite.prisma",
    "db:push:prod": "prisma db push --schema=prisma/schema.postgres.prisma",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node scripts/set-admin.js admin admin",
    "db:generate": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "db:generate:prod": "prisma generate --schema=prisma/schema.postgres.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "lokijs": "^1.5.12",
    "next": "^14.2.14",
    "next-auth": "^4.24.13",
    "node-cron": "^3.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "technicalindicators": "^3.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
