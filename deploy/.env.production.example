# 生产环境配置模板
# 复制此文件为 .env 并修改相应配置

# 数据库连接 (本地 PostgreSQL)
DATABASE_URL="postgresql://finance_user:your_secure_password@localhost:5432/finance_news"

# AI API Keys
DEEPSEEK_API_KEY="sk-xxx"
QWEN_API_KEY="sk-xxx"
TAVILY_API_KEY="tvly-dev-xxx"

# 股票数据
TUSHARE_TOKEN="your_tushare_token"
TUSHARE_API_URL="http://api.tushare.pro"

# NextAuth.js
NEXTAUTH_SECRET="your_random_secret_key_at_least_32_chars"
NEXTAUTH_URL="https://your-domain.com"

# 可选: 如果使用外部 PostgreSQL
# DATABASE_URL="postgresql://user:password@your-db-host:5432/finance_news?sslmode=require"
