# 定时任务配置 - 新闻抓取
# 文件位置: /etc/cron.d/finance-news-fetcher

# 每 5 分钟抓取一次新闻
*/5 * * * * www-data cd /var/www/finance-news && /usr/bin/node scripts/fetcher.js >> /var/log/finance-news/fetcher.log 2>&1

# 每天凌晨 3 点清理旧日志
0 3 * * * www-data find /var/log/finance-news -name "*.log" -mtime +7 -delete

# 每周日凌晨 4 点备份数据库
0 4 * * 0 www-data pg_dump -U finance_user finance_news > /var/backups/finance_news_$(date +\%Y\%m\%d).sql
