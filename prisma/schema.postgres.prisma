// 生产环境 - PostgreSQL 数据库
// 使用方式: npx prisma db push --schema=prisma/schema.postgres.prisma
// Vercel 部署时使用此 Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model News {
  id              String   @id
  source          String
  title           String
  brief           String?
  content         String?
  url             String?
  published_at    BigInt
  ai_note         String?
  sentiment_score Float?
  created_at      BigInt

  @@index([source, published_at])
}

model Report {
  id          String   @id @default(uuid())
  start_time  BigInt
  end_time    BigInt
  content     String
  created_at  BigInt

  @@index([created_at])
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String?  @unique
  password  String
  name      String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockDaily {
  ts_code    String
  trade_date String
  open       Float
  high       Float
  low        Float
  close      Float
  pre_close  Float
  change     Float
  pct_chg    Float
  vol        Float
  amount     Float?

  @@id([ts_code, trade_date])
}
