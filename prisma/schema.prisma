// Prisma Schema 配置
// 
// 本项目使用双 Schema 配置：
// - 本地开发: prisma/schema.sqlite.prisma (SQLite)
// - 生产环境: prisma/schema.postgres.prisma (PostgreSQL)
//
// 使用方式：
// - 本地开发: npm run db:push (使用 SQLite)
// - 生产部署: npm run db:push:prod (使用 PostgreSQL)
//
// Vercel 部署时会自动使用 schema.postgres.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model News {
  id              String   @id
  source          String
  title           String
  brief           String?
  content         String?
  url             String?
  published_at    BigInt
  ai_note         String?
  sentiment_score Float?
  created_at      BigInt

  @@index([source, published_at])
}

model Report {
  id          String   @id @default(uuid())
  start_time  BigInt
  end_time    BigInt
  content     String
  created_at  BigInt

  @@index([created_at])
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String?  @unique
  password  String
  name      String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockDaily {
  ts_code    String
  trade_date String
  open       Float
  high       Float
  low        Float
  close      Float
  pre_close  Float
  change     Float
  pct_chg    Float
  vol        Float
  amount     Float?

  @@id([ts_code, trade_date])
}
